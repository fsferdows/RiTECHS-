{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*).(mp4|png|jpg|jpeg|svg|gif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
